[app]
title = KivyMD Test
package.name = kivymdtest
package.domain = org.test
version = 1.0
source.dir = .
source.include_exts = py
requirements = python3==3.11.5,hostpython3==3.11.5,kivy,kivymd
orientation = portrait
fullscreen = 0
android.api = 31
android.minapi = 21
android.ndk = 25b
android.archs = arm64-v8a
android.accept_sdk_license = True
android.permissions = INTERNET
android.allow_backup = True
p4a.branch = master
log_level = 2
warn_on_root = 0