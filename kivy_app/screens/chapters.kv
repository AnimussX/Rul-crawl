<ChaptersScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        MDLabel:
            id: status_label
            halign: 'center'
        ScrollView:
            MDList:
                id: chapters_list
        MDBoxLayout:
            size_hint_y: None
            height: dp(48)
            MDRaisedButton:
                text: "Выбрать все"
                on_release: root.select_all()
            MDRaisedButton:
                text: "Снять все"
                on_release: root.deselect_all()
        MDBoxLayout:
            size_hint_y: None
            height: dp(48)
            MDCheckbox:
                id: force_check
                size_hint: None, None
                size: dp(48), dp(48)
            MDLabel:
                text: "Принудительно"
            MDCheckbox:
                id: ignore_images
                size_hint: None, None
                size: dp(48), dp(48)
            MDLabel:
                text: "Игнор. ошибки изобр."
            MDCheckbox:
                id: ignore_errors
                size_hint: None, None
                size: dp(48), dp(48)
            MDLabel:
                text: "Игнор. ошибки глав"
        MDRaisedButton:
            text: "Загрузить выбранные"
            on_release: root.start_download()
        MDRaisedButton:
            text: "Назад"
            on_release: app.sm.current = 'novel_info'