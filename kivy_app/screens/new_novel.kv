<NewNovelScreen>:
    MDBoxLayout:
        orientation: 'vertical'
        padding: dp(20)
        spacing: dp(10)

        MDTextField:
            id: url_field
            hint_text: "Ссылка на новеллу"
        MDRaisedButton:
            text: "Получить информацию"
            on_release: root.fetch_info()

        MDTextField:
            id: title_field
            hint_text: "Название (заполнится автоматически)"

        MDLabel:
            id: status_label
            halign: 'center'

        MDRaisedButton:
            text: "Добавить"
            on_release: root.confirm_add()
        MDRaisedButton:
            text: "Назад"
            on_release: app.sm.current = 'main_menu'